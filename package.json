{
  "name": "promptmaster-ai",
  "displayName": "PromptMaster AI",
  "description": "A VS Code sidebar assistant with offline prompt enhancement and API-powered smart chat.",
  "version": "1.0.3",
  "publisher": "AvishekGiri",
  "engines": {
    "vscode": ">=1.80.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "prompt",
    "ai",
    "vscode",
    "sidebar",
    "gemini",
    "openai",
    "anthropic",
    "ollama"
  ],
  "activationEvents": [
    "onView:promptmasterSidebar"
  ],
  "main": "./dist/extension.js",
  "bin": {
    "avishek": "./dist/cli.js"
  },
  "icon": "media/icon.png",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "promptmasterAI",
          "title": "PromptMaster AI",
          "icon": "media/robot-icon.svg"
        }
      ]
    },
    "views": {
      "promptmasterAI": [
        {
          "type": "webview",
          "id": "promptmasterSidebar",
          "name": "PromptMaster AI"
        }
      ]
    },
    "commands": [
      {
        "command": "promptmasterAI.focusSidebar",
        "title": "PromptMaster AI: Focus Sidebar"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "build:cli": "node esbuild.js --production",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/im-coderavi/MasterPrompt-ai.git"
  },
  "homepage": "https://github.com/im-coderavi/MasterPrompt-ai#readme",
  "bugs": {
    "url": "https://github.com/im-coderavi/MasterPrompt-ai/issues"
  },
  "license": "MIT"
}
